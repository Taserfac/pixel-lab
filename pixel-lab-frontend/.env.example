# 【文件路径】.env.example
# 【文件功能说明】环境变量示例文件
# 复制此文件为 .env.development 和 .env.production 并修改配置

# ============================================
# 后端 API 基础地址
# 开发环境使用本地地址，生产环境使用部署地址
# ============================================
VITE_API_BASE_URL=

# ============================================
# 应用名称
# ============================================
VITE_APP_TITLE=Pixel Lab Pro

# ============================================
# 应用版本
# ============================================
VITE_APP_VERSION=1.0.0
