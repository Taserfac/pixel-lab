# 【文件路径】.gitignore
# 【文件功能说明】Git 忽略文件配置

# 依赖目录
node_modules
.pnp
.pnp.js

# 构建输出
dist
dist-ssr
*.local

# 环境变量（包含敏感信息）
.env
.env.local
.env.*.local

# 编辑器配置
.idea
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 操作系统文件
.DS_Store
Thumbs.db

# 日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 测试覆盖率
coverage

# 临时文件
*.log
*.tmp
.temp
