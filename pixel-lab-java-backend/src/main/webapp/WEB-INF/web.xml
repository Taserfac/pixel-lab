<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>Pixel Lab Java Backend</display-name>

  <context-param>
    <param-name>appConfigLocation</param-name>
    <param-value>/WEB-INF/classes/app.properties</param-value>
  </context-param>

  <listener>
    <listener-class>com.pixellab.listener.AppContextListener</listener-class>
  </listener>
  <listener>
    <listener-class>com.pixellab.listener.SessionListener</listener-class>
  </listener>
  <listener>
    <listener-class>com.pixellab.listener.RequestListener</listener-class>
  </listener>

  <filter>
    <filter-name>CharacterEncodingFilter</filter-name>
    <filter-class>com.pixellab.filter.CharacterEncodingFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>CharacterEncodingFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <filter>
    <filter-name>CorsFilter</filter-name>
    <filter-class>com.pixellab.filter.CorsFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>CorsFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <filter>
    <filter-name>RequestLogFilter</filter-name>
    <filter-class>com.pixellab.filter.RequestLogFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>RequestLogFilter</filter-name>
    <url-pattern>/api/*</url-pattern>
  </filter-mapping>

  <filter>
    <filter-name>AuthFilter</filter-name>
    <filter-class>com.pixellab.filter.AuthFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/api/*</url-pattern>
  </filter-mapping>

  <filter>
    <filter-name>AdminFilter</filter-name>
    <filter-class>com.pixellab.filter.AdminFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>AdminFilter</filter-name>
    <url-pattern>/api/admin/*</url-pattern>
  </filter-mapping>

  <filter>
    <filter-name>CacheControlFilter</filter-name>
    <filter-class>com.pixellab.filter.CacheControlFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>CacheControlFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <filter>
    <filter-name>SpaFallbackFilter</filter-name>
    <filter-class>com.pixellab.filter.SpaFallbackFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>SpaFallbackFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <servlet>
    <servlet-name>AuthServlet</servlet-name>
    <servlet-class>com.pixellab.servlet.AuthServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AuthServlet</servlet-name>
    <url-pattern>/api/auth/*</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ImageServlet</servlet-name>
    <servlet-class>com.pixellab.servlet.ImageServlet</servlet-class>
    <multipart-config>
      <max-file-size>20971520</max-file-size>
      <max-request-size>41943040</max-request-size>
      <file-size-threshold>1048576</file-size-threshold>
    </multipart-config>
  </servlet>
  <servlet-mapping>
    <servlet-name>ImageServlet</servlet-name>
    <url-pattern>/api/images/*</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>CommunityServlet</servlet-name>
    <servlet-class>com.pixellab.servlet.CommunityServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>CommunityServlet</servlet-name>
    <url-pattern>/api/community/*</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AlbumServlet</servlet-name>
    <servlet-class>com.pixellab.servlet.AlbumServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AlbumServlet</servlet-name>
    <url-pattern>/api/albums/*</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AdminServlet</servlet-name>
    <servlet-class>com.pixellab.servlet.AdminServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminServlet</servlet-name>
    <url-pattern>/api/admin/*</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AiServlet</servlet-name>
    <servlet-class>com.pixellab.servlet.AiServlet</servlet-class>
    <multipart-config>
      <max-file-size>20971520</max-file-size>
      <max-request-size>83886080</max-request-size>
      <file-size-threshold>1048576</file-size-threshold>
    </multipart-config>
  </servlet>
  <servlet-mapping>
    <servlet-name>AiServlet</servlet-name>
    <url-pattern>/api/ai/*</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>HealthServlet</servlet-name>
    <servlet-class>com.pixellab.servlet.HealthServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>HealthServlet</servlet-name>
    <url-pattern>/api/health</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>SocialServlet</servlet-name>
    <servlet-class>com.pixellab.servlet.SocialServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>SocialServlet</servlet-name>
    <url-pattern>/api/social/*</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>UploadFileServlet</servlet-name>
    <servlet-class>com.pixellab.servlet.UploadFileServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>UploadFileServlet</servlet-name>
    <url-pattern>/uploads/*</url-pattern>
  </servlet-mapping>

  <session-config>
    <session-timeout>10080</session-timeout>
    <cookie-config>
      <http-only>true</http-only>
      <path>/</path>
    </cookie-config>
    <tracking-mode>COOKIE</tracking-mode>
  </session-config>

  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
  </welcome-file-list>

</web-app>
