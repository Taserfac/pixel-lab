# Pixel Lab production environment.
# Copy to /etc/pixel-lab/pixel-lab.env on the server and edit values.

APP_ENV=production

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pixel_lab
DB_USER=pixel_lab_app
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_POOL_SIZE=10

UPLOAD_PATH=/opt/pixel-lab/uploads
UPLOAD_MAX_SIZE=20971520

# Empty means same-origin access through Nginx/Tomcat.
CORS_ALLOWED_ORIGINS=
SESSION_TIMEOUT_MINUTES=10080

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=CHANGE_ME_DEEPSEEK_KEY
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_IMAGE_MODEL=deepseek-chat

# Leave empty unless a drawing backend such as ComfyUI is deployed on the server.
COMFYUI_BASE_URL=
