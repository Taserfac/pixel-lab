# 【文件路径】.env.example
# 【文件功能说明】环境变量示例文件
# 复制此文件为 .env 并修改配置

# ============================================
# 服务器配置
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# MySQL 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=pixel_lab

# ============================================
# JWT 配置
# ============================================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ============================================
# 文件上传配置
# ============================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp

# ============================================
# AI 配置
# ============================================
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: ComfyUI image generation service.
# When empty, AI draw mode returns drawing prompts only.
DEEPSEEK_IMAGE_PROVIDER=comfyui
DEEPSEEK_IMAGE_API_URL=http://127.0.0.1:8188
DEEPSEEK_IMAGE_API_KEY=
DEEPSEEK_IMAGE_MODEL=sd_turbo.safetensors
COMFYUI_CHECKPOINT=sd_turbo.safetensors
COMFYUI_STEPS=4
COMFYUI_CFG=1
COMFYUI_DENOISE=0.68
COMFYUI_MAX_SIZE=768
COMFYUI_TIMEOUT_MS=180000
