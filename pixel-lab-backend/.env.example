# 【文件路径】.env.example
# 【文件功能说明】环境变量示例文件
# 复制此文件为 .env 并修改配置

# ============================================
# 服务器配置
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# MySQL 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=pixel_lab

# ============================================
# JWT 配置
# ============================================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ============================================
# 文件上传配置
# ============================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp
